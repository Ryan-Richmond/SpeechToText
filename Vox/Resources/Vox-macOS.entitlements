<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Sandbox: required for App Store distribution -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Microphone access for dictation -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Outbound network: required ONLY for first-launch model download
         and (Phase 2) opt-in BYOK cloud fallback. ModelDownloadService and
         CloudLLMEngine are the only files allowed to make network calls;
         see vox-privacy-audit. -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- File access for downloaded models in Application Support -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
