<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Group: shared container with future keyboard extension (Sprint 9). -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.llc.meridian.vox</string>
    </array>

    <!-- Increased memory limit for ML model loading on 8GB iPhones.
         Apple grants this on a per-app review basis; document use case in
         App Store submission. -->
    <key>com.apple.developer.kernel.increased-memory-limit</key>
    <true/>
</dict>
</plist>
